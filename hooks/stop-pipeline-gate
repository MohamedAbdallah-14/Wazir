#!/usr/bin/env node

/**
 * Stop hook: blocks premature completion when pipeline has unchecked items.
 *
 * Uses narrow completion-signal detection — only blocks when the agent
 * says "task complete" / "all done" / etc. AND has unchecked items.
 * Normal conversation turns pass through unconditionally.
 *
 * Block: stderr JSON + exit 2
 * Approve: stdout JSON + exit 0
 */

import { readFileSync } from 'node:fs';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';

import { evaluateStopGate } from '../tooling/src/hooks/stop-pipeline-gate.js';

const hooksDir = dirname(fileURLToPath(import.meta.url));
const projectRoot = dirname(hooksDir);

try {
  // Read stdin — Stop hook receives the agent's message context
  let agentMessage = '';
  try {
    const input = readFileSync(0, 'utf8');
    const payload = input.trim() ? JSON.parse(input) : {};
    agentMessage = payload.assistant_message || payload.message || payload.content || '';
  } catch { /* ignore stdin errors */ }

  const latestPath = join(projectRoot, '.wazir', 'runs', 'latest');
  const result = evaluateStopGate(latestPath, agentMessage);

  if (result.decision === 'block') {
    process.stderr.write(JSON.stringify(result) + '\n');
    process.exit(2);
  }

  process.stdout.write(JSON.stringify({ decision: 'approve' }) + '\n');
  process.exit(0);
} catch (error) {
  // Fail-closed when run might be active
  process.stderr.write(JSON.stringify({
    decision: 'block',
    reason: `Stop hook error: ${error.message}`,
  }) + '\n');
  process.exit(2);
}
