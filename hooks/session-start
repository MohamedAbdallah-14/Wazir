#!/usr/bin/env node
import { existsSync, readFileSync, statSync } from 'node:fs';
import { execFileSync } from 'node:child_process';
import { dirname, join } from 'node:path';
import { fileURLToPath } from 'node:url';

import { findActivePhase, extractCurrentStep, resolveActiveScope } from '../tooling/src/hooks/phase-injector.js';

const hooksDir = dirname(fileURLToPath(import.meta.url));
const projectRoot = dirname(hooksDir);
const skillFile = join(projectRoot, 'skills', 'using-skills', 'SKILL.md');

if (existsSync(skillFile)) {
  const content = readFileSync(skillFile, 'utf-8');
  process.stdout.write(
    `<EXTREMELY_IMPORTANT>\n` +
    `You have skills.\n\n` +
    `**Below is the full content of your 'wz:using-skills' skill:**\n\n` +
    `${content}\n` +
    `</EXTREMELY_IMPORTANT>\n`,
  );
} else {
  process.stdout.write(
    `<system-reminder>\n` +
    `WARNING: wz:using-skills skill not found at ${skillFile}\n` +
    `The Wazir skill bootstrap is not available. Skills will not be auto-discovered.\n` +
    `Run: check that skills/using-skills/SKILL.md exists.\n` +
    `</system-reminder>\n`,
  );
}

// ---------------------------------------------------------------------------
// Index freshness check (AC-D2.1 through AC-D2.3)
// ---------------------------------------------------------------------------

const FRESHNESS_THRESHOLD_MS = 3600 * 1000; // 1 hour

function refreshIndex() {
  try {
    const wazirPath = execFileSync('which', ['wazir'], { encoding: 'utf8', timeout: 5000 }).trim();
    if (!wazirPath) return;

    // Check index freshness via stats
    let needsRefresh = true;
    try {
      const statsOut = execFileSync(wazirPath, ['index', 'stats', '--json'], {
        encoding: 'utf8',
        timeout: 10000,
        cwd: projectRoot,
      });
      const stats = JSON.parse(statsOut);
      if (stats.database_path) {
        const mtime = statSync(stats.database_path).mtimeMs;
        const age = Date.now() - mtime;
        if (age < FRESHNESS_THRESHOLD_MS) {
          needsRefresh = false;
        }
      }
    } catch {
      // No index or stats failed — needs build
    }

    if (!needsRefresh) return;

    // Run refresh (or build if no index)
    try {
      execFileSync(wazirPath, ['index', 'refresh'], {
        encoding: 'utf8',
        timeout: 30000,
        cwd: projectRoot,
      });
      process.stderr.write('[wazir:session-start] Index refreshed.\n');
    } catch {
      try {
        execFileSync(wazirPath, ['index', 'build'], {
          encoding: 'utf8',
          timeout: 30000,
          cwd: projectRoot,
        });
        process.stderr.write('[wazir:session-start] Index built.\n');
      } catch (err) {
        process.stderr.write(`[wazir:session-start] WARN: index refresh/build failed: ${err.message}\n`);
      }
    }
  } catch {
    process.stderr.write('[wazir:session-start] WARN: wazir CLI not found, skipping index refresh.\n');
  }
}

refreshIndex();

// ---------------------------------------------------------------------------
// Pipeline status injection (Layer 1 enforcement)
// ---------------------------------------------------------------------------

function injectPipelineStatus() {
  try {
    const markerPath = join(projectRoot, '.wazir', 'state', 'pipeline-active');
    const latestPath = join(projectRoot, '.wazir', 'runs', 'latest');

    if (existsSync(markerPath) && !existsSync(latestPath)) {
      process.stdout.write(
        `<system-reminder>\n` +
        `BOOTSTRAP REQUIRED: A Wazir pipeline session is active but no run exists.\n` +
        `Run \`wazir capture ensure\` BEFORE doing anything else.\n` +
        `Please try 100% compliance with Wazir pipeline and skill usage.\n` +
        `</system-reminder>\n`,
      );
      return;
    }

    if (!existsSync(latestPath)) return;

    const phasesDir = join(latestPath, 'phases');
    if (!existsSync(phasesDir)) return;

    const active = findActivePhase(phasesDir);
    if (!active) return;

    const step = extractCurrentStep(active.content);
    if (!step) return;

    // Count completed items for progress summary
    const checkedCount = step.stepNum - 1;

    let output = `<system-reminder>\n`;
    output += `PIPELINE STATUS: Phase ${active.phase} — ACTIVE (step ${step.stepNum} of ${step.totalSteps})\n`;

    // Scope stack breadcrumb
    const latestRunDir = join(projectRoot, '.wazir', 'runs', 'latest');
    const scope = resolveActiveScope(latestRunDir);
    if (scope.type === 'skill') {
      const skillActive = findActivePhase(scope.phasesDir);
      const skillStep = skillActive ? extractCurrentStep(skillActive.content) : null;
      const skillPhaseName = skillActive?.phase || 'unknown';
      const skillStepInfo = skillStep ? ` (step ${skillStep.stepNum} of ${skillStep.totalSteps})` : '';
      output += `SKILL SCOPE: Pipeline: ${active.phase} > Skill: ${scope.skill} > Phase: ${skillPhaseName}${skillStepInfo}\n`;
      if (skillStep) {
        output += `SKILL CURRENT: ${skillStep.current}\n`;
      }
    }

    if (checkedCount > 0) {
      output += `COMPLETED: steps 1-${checkedCount}\n`;
    }
    output += `CURRENT: ${step.current}\n`;
    if (step.next) {
      output += `NEXT: ${step.next}\n`;
    }
    output += `</system-reminder>\n`;

    process.stdout.write(output);
  } catch {
    // Fail-open: no injection on error
  }
}

injectPipelineStatus();

process.stdout.write(
  `<cli-bootstrap-guidance>\n` +
  `## CLI Bootstrap\n\n` +
  `Run the following checks at session start:\n\n` +
  `1. Run \`wazir doctor --json\` to check repo health.\n` +
  `2. Run \`wazir index refresh\` to update the index.\n` +
  `   - If no index exists, run \`wazir index build && wazir index summarize --tier all\`.\n` +
  `3. Check \`<state-root>/runs/latest\` for previous run ID.\n` +
  `   - If previous run is incomplete, resume it.\n` +
  `   - Otherwise run \`wazir capture init --run <new-id> --phase clarify --status starting\`.\n` +
  `</cli-bootstrap-guidance>\n`,
);
process.exit(0);
