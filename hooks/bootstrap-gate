#!/usr/bin/env node
import { readFileSync } from 'node:fs';
import { dirname } from 'node:path';
import { fileURLToPath } from 'node:url';
import { evaluateBootstrapGate } from '../tooling/src/hooks/bootstrap-gate.js';

const projectRoot = process.cwd() || dirname(dirname(fileURLToPath(import.meta.url)));

try {
  let payload = {};
  try {
    const stdin = readFileSync(0, 'utf8');
    if (stdin.trim()) payload = JSON.parse(stdin);
  } catch { /* no stdin */ }

  const tool = payload.tool_name || '';
  const command = payload.tool_input?.command || '';
  const filePath = payload.tool_input?.file_path || '';
  const result = evaluateBootstrapGate(projectRoot, { tool, command, filePath });

  if (result.decision === 'deny') {
    process.stdout.write(JSON.stringify({
      hookSpecificOutput: { hookEventName: 'PreToolUse', permissionDecision: 'deny' },
      systemMessage: result.systemMessage || result.reason,
    }) + '\n');
    process.exit(2);
  }

  process.stdout.write('{}\n');
  process.exit(0);
} catch (error) {
  process.stderr.write(`[bootstrap-gate] ${error.message}\n`);
  process.stdout.write('{}\n');
  process.exit(0);
}
