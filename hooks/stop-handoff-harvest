#!/usr/bin/env node

// stop-handoff-harvest hook
// Harvests final handoff notes and persists stop-time observability data.
// Skips TabManager-dependent operations when not running inside an IDE.

const IS_IDE = !!(
  process.env.VSCODE_PID ||
  process.env.CURSOR_PID ||
  (process.env.TERM_PROGRAM && process.env.TERM_PROGRAM === 'vscode')
);

if (!IS_IDE) {
  // Not in an IDE — TabManager is unavailable, skip gracefully
  process.stdout.write(
    '{"status":"skipped","reason":"not in IDE, TabManager unavailable"}\n',
  );
  process.exit(0);
}

// IDE-mode: attempt TabManager-dependent operations
try {
  // Placeholder for TabManager-dependent handoff harvest logic.
  // When running inside VS Code / Cursor, the IDE provides TabManager
  // and this section would interact with it.
  process.stdout.write('{"status":"ok"}\n');
  process.exit(0);
} catch (err) {
  // Capture failure silently per failure_behavior: { mode: capture, exit_code: 0 }
  process.stderr.write(
    `[wazir:stop-handoff-harvest] WARN: ${err.message}\n`,
  );
  process.exit(0);
}
